# Shopify App Credentials
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
SCOPES=read_products,write_products,read_orders,write_discounts,read_inventory

# App Configuration (Vercel URL)
SHOPIFY_APP_URL=https://your-project.vercel.app

# Database (Vercel Postgres or Neon)
# Get this from Vercel Dashboard → Storage → Postgres → .env.local
DATABASE_URL="postgres://user:password@host/database?sslmode=require"

# For local development with SQLite (optional)
# DATABASE_URL="file:./database.db"

# Shopify Custom Domain (optional)
# SHOP_CUSTOM_DOMAIN=my-custom-domain.com
